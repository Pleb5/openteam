{
  "browser": {
    "headless": false,
    "executablePath": "/usr/bin/chromium",
    "agentBrowserTools": {
      "enabled": true,
      "allowedDomains": ["127.0.0.1", "localhost"]
    },
    "mcp": {
      "name": "playwright",
      "command": [
        "bunx",
        "@playwright/mcp@latest"
      ],
      "environment": {
        "PLAYWRIGHT_HEADLESS": "0"
      }
    }
  },
  "opencode": {
    "retry": {
      "maxSameModelAttempts": 2,
      "maxTotalAttempts": 5,
      "initialBackoffMs": 2000,
      "maxBackoffMs": 30000
    }
  },
  "providers": {
    "github.com": {
      "type": "github",
      "host": "github.com",
      "token": "$OPENTEAM_GITHUB_TOKEN",
      "private": false
    },
    "gitlab.com": {
      "type": "gitlab",
      "host": "gitlab.com",
      "token": "$OPENTEAM_GITLAB_TOKEN",
      "visibility": "public"
    }
  },
  "verification": {
    "autoRunAfterWorker": false,
    "defaultRunners": {
      "code": ["repo-native"],
      "web": ["repo-native", "agent-browser", "browser"]
    },
    "runners": {
      "desktop-command": {
        "enabled": true
      },
      "agent-browser": {
        "enabled": true,
        "environment": {
          "AGENT_BROWSER_ALLOWED_DOMAINS": "127.0.0.1,localhost"
        }
      },
      "android-adb": {
        "enabled": false
      },
      "ios-simulator": {
        "enabled": false
      }
    }
  },
  "modelProfiles": {
    "builder-default": {
      "model": "openai/gpt-5.5",
      "variant": "xhigh",
      "description": "Primary implementation model. Prefer subscription-backed providers before usage-based fallbacks.",
      "fallbackModelProfiles": [
        "builder-gpt54-openai",
        "builder-gpt55-opencode",
        "builder-claude-sonnet"
      ]
    },
    "builder-gpt54-openai": {
      "model": "openai/gpt-5.4",
      "variant": "xhigh",
      "description": "Subscription-backed OpenAI fallback for implementation."
    },
    "builder-gpt55-opencode": {
      "model": "opencode/gpt-5.5",
      "variant": "high",
      "description": "Same logical model through a usage-based provider. Keep after subscription-backed fallbacks."
    },
    "builder-claude-sonnet": {
      "model": "opencode/claude-sonnet-4-6",
      "variant": "max",
      "description": "Different model family fallback for implementation."
    },
    "analysis-default": {
      "model": "openai/gpt-5.5",
      "variant": "medium",
      "description": "Default model for research, QA, and triage.",
      "fallbackModelProfiles": [
        "analysis-gpt54-openai",
        "analysis-gpt55-opencode",
        "analysis-claude-sonnet"
      ]
    },
    "analysis-gpt54-openai": {
      "model": "openai/gpt-5.4",
      "variant": "xhigh",
      "description": "Subscription-backed OpenAI fallback for analysis work."
    },
    "analysis-gpt55-opencode": {
      "model": "opencode/gpt-5.5",
      "variant": "high",
      "description": "Same logical analysis model through a usage-based provider."
    },
    "analysis-claude-sonnet": {
      "model": "opencode/claude-sonnet-4-6",
      "variant": "max",
      "description": "Different model family fallback for analysis."
    },
    "control-default": {
      "model": "openai/gpt-5.5",
      "variant": "medium",
      "description": "Control-plane and orchestrator model.",
      "fallbackModelProfiles": [
        "control-gpt54-openai",
        "control-gpt55-opencode",
        "control-haiku"
      ]
    },
    "control-gpt54-openai": {
      "model": "openai/gpt-5.4",
      "variant": "xhigh",
      "description": "Subscription-backed OpenAI fallback for control-plane requests."
    },
    "control-gpt55-opencode": {
      "model": "opencode/gpt-5.5",
      "variant": "high",
      "description": "Usage-based provider fallback for control-plane requests."
    },
    "control-haiku": {
      "model": "opencode/claude-haiku-4-5",
      "description": "Small-model fallback for simple routing/control tasks."
    }
  },
  "workerProfiles": {
    "builder": {
      "modelProfile": "builder-default"
    },
    "researcher": {
      "modelProfile": "analysis-default"
    },
    "qa": {
      "modelProfile": "analysis-default"
    },
    "triager": {
      "modelProfile": "analysis-default"
    },
    "orchestrator": {
      "modelProfile": "control-default"
    }
  },
  "reporting": {
    "dmRelays": [
      "wss://relay.example.com"
    ],
    "outboxRelays": [
      "wss://relay.example.com"
    ],
    "relayListBootstrapRelays": [
      "wss://relay.damus.io",
      "wss://purplepag.es"
    ],
    "appDataRelays": [
      "wss://relay.example.com"
    ],
    "signerRelays": [
      "wss://relay.example.com"
    ],
    "allowFrom": [
      "npub1operator..."
    ],
    "reportTo": [
      "npub1operator..."
    ],
    "pollIntervalMs": 5000,
    "dmObservationMode": "terminal",
    "dmDigestIntervalMs": 1800000,
    "dmWarningThrottleMs": 1800000
  },
  "nostr_git": {
    "graspServers": [
      "wss://replace-with-grasp-server"
    ],
    "gitDataRelays": [
      "wss://relay.example.com",
      "wss://relay.damus.io",
      "wss://nos.lol"
    ],
    "repoAnnouncementRelays": [
      "wss://relay.ngit.dev",
      "wss://gitnostr.com"
    ],
    "forkGitOwner": "",
    "forkRepoPrefix": "",
    "forkCloneUrlTemplate": ""
  },
  "agents": {
    "orchestrator-01": {
      "identity": {
        "npub": "npub1orchestrator...",
        "sec": "$OPENTEAM_ORCHESTRATOR_01_SEC",
        "bunkerProfile": "orchestrator-01",
        "nakClientKey": "$NOSTR_CLIENT_KEY"
      }
    },
    "triager-01": {
      "identity": {
        "npub": "npub1triager...",
        "sec": "$OPENTEAM_TRIAGER_01_SEC",
        "bunkerProfile": "triager-01",
        "nakClientKey": "$NOSTR_CLIENT_KEY"
      }
    },
    "builder-01": {
      "identity": {
        "npub": "npub1builder...",
        "sec": "$OPENTEAM_BUILDER_01_SEC",
        "bunkerProfile": "builder-01",
        "nakClientKey": "$NOSTR_CLIENT_KEY"
      }
    },
    "researcher-01": {
      "identity": {
        "npub": "npub1researcher...",
        "sec": "$OPENTEAM_RESEARCHER_01_SEC",
        "bunkerProfile": "researcher-01",
        "nakClientKey": "$NOSTR_CLIENT_KEY"
      }
    },
    "qa-01": {
      "identity": {
        "npub": "npub1qa...",
        "sec": "$OPENTEAM_QA_01_SEC",
        "bunkerProfile": "qa-01",
        "nakClientKey": "$NOSTR_CLIENT_KEY"
      }
    }
  }
}
