{
  "browser": {
    "headless": false,
    "executablePath": "/usr/bin/chromium",
    "agentBrowserTools": {
      "enabled": false,
      "allowedDomains": ["127.0.0.1", "localhost"]
    },
    "mcp": {
      "name": "playwright",
      "command": [
        "bunx",
        "@playwright/mcp@latest"
      ],
      "environment": {
        "PLAYWRIGHT_HEADLESS": "0"
      }
    }
  },
  "providers": {
    "github.com": {
      "type": "github",
      "host": "github.com",
      "token": "$OPENTEAM_GITHUB_TOKEN",
      "private": false
    },
    "gitlab.com": {
      "type": "gitlab",
      "host": "gitlab.com",
      "token": "$OPENTEAM_GITLAB_TOKEN",
      "visibility": "public"
    }
  },
  "verification": {
    "autoRunAfterWorker": false,
    "defaultRunners": {
      "code": ["repo-native"],
      "web": ["repo-native", "browser"]
    },
    "runners": {
      "desktop-command": {
        "enabled": true
      },
      "agent-browser": {
        "enabled": false,
        "environment": {
          "AGENT_BROWSER_ALLOWED_DOMAINS": "127.0.0.1,localhost"
        }
      },
      "android-adb": {
        "enabled": false
      },
      "ios-simulator": {
        "enabled": false
      }
    }
  },
  "modelProfiles": {
    "builder-default": {
      "model": "opencode/gpt-5.5",
      "variant": "high",
      "description": "Default model for implementation workers."
    },
    "research-default": {
      "model": "opencode/gpt-5.5",
      "variant": "medium",
      "description": "Default model for read-only analysis and QA."
    }
  },
  "workerProfiles": {
    "builder": {
      "modelProfile": "builder-default"
    },
    "researcher": {
      "modelProfile": "research-default"
    },
    "qa": {
      "modelProfile": "research-default"
    },
    "triager": {
      "modelProfile": "research-default"
    },
    "orchestrator": {
      "modelProfile": "research-default"
    }
  },
  "reporting": {
    "dmRelays": [
      "wss://relay.example.com"
    ],
    "outboxRelays": [
      "wss://relay.example.com"
    ],
    "relayListBootstrapRelays": [
      "wss://relay.damus.io",
      "wss://purplepag.es"
    ],
    "appDataRelays": [
      "wss://relay.example.com"
    ],
    "signerRelays": [
      "wss://relay.example.com"
    ],
    "allowFrom": [
      "npub1operator..."
    ],
    "reportTo": [
      "npub1operator..."
    ],
    "pollIntervalMs": 5000,
    "dmObservationMode": "terminal",
    "dmDigestIntervalMs": 1800000,
    "dmWarningThrottleMs": 1800000
  },
  "nostr_git": {
    "graspServers": [
      "wss://replace-with-grasp-server"
    ],
    "gitDataRelays": [
      "wss://relay.example.com",
      "wss://relay.damus.io",
      "wss://nos.lol"
    ],
    "repoAnnouncementRelays": [
      "wss://relay.ngit.dev",
      "wss://gitnostr.com"
    ],
    "forkGitOwner": "",
    "forkRepoPrefix": "",
    "forkCloneUrlTemplate": ""
  },
  "agents": {
    "orchestrator-01": {
      "identity": {
        "npub": "npub1orchestrator...",
        "sec": "$OPENTEAM_ORCHESTRATOR_01_SEC",
        "bunkerProfile": "orchestrator-01",
        "nakClientKey": "$NOSTR_CLIENT_KEY"
      }
    },
    "triager-01": {
      "identity": {
        "npub": "npub1triager...",
        "sec": "$OPENTEAM_TRIAGER_01_SEC",
        "bunkerProfile": "triager-01",
        "nakClientKey": "$NOSTR_CLIENT_KEY"
      }
    },
    "builder-01": {
      "identity": {
        "npub": "npub1builder...",
        "sec": "$OPENTEAM_BUILDER_01_SEC",
        "bunkerProfile": "builder-01",
        "nakClientKey": "$NOSTR_CLIENT_KEY"
      }
    },
    "researcher-01": {
      "identity": {
        "npub": "npub1researcher...",
        "sec": "$OPENTEAM_RESEARCHER_01_SEC",
        "bunkerProfile": "researcher-01",
        "nakClientKey": "$NOSTR_CLIENT_KEY"
      }
    },
    "qa-01": {
      "identity": {
        "npub": "npub1qa...",
        "sec": "$OPENTEAM_QA_01_SEC",
        "bunkerProfile": "qa-01",
        "nakClientKey": "$NOSTR_CLIENT_KEY"
      }
    }
  }
}
