{
  "browser": {
    "headless": false,
    "executablePath": "/usr/bin/chromium",
    "mcp": {
      "name": "playwright",
      "command": ["bunx", "@playwright/mcp@latest"],
      "environment": {
        "PLAYWRIGHT_HEADLESS": "0"
      }
    }
  },
  "reporting": {
    "allowFrom": ["npub1operator..."],
    "reportTo": ["npub1operator..."],
    "pollIntervalMs": 5000
  },
  "agents": {
    "triager-01": {
      "identity": {
        "npub": "npub1triager...",
        "sec": "$OPENTEAM_TRIAGER_01_SEC",
        "bunkerProfile": "triager-01",
        "nakClientKey": "$NOSTR_CLIENT_KEY"
      },
      "reporting": {
        "dmRelays": ["wss://relay.example.com"],
        "outboxRelays": ["wss://relay.example.com"],
        "relayListBootstrapRelays": ["wss://relay.damus.io", "wss://purplepag.es"],
        "appDataRelays": ["wss://relay.example.com"],
        "signerRelays": ["wss://relay.example.com"],
        "reportTo": ["npub1operator..."],
        "allowFrom": ["npub1operator..."]
      },
      "nostr_git": {
        "graspServers": ["wss://replace-with-grasp-server"],
        "gitDataRelays": [
          "wss://relay.damus.io",
          "wss://nos.lol",
          "wss://relay.example.com",
          "wss://relay.ngit.dev",
          "wss://gitnostr.com"
        ]
      }
    },
    "builder-01": {
      "identity": {
        "npub": "npub1builder...",
        "sec": "$OPENTEAM_BUILDER_01_SEC",
        "bunkerProfile": "builder-01",
        "nakClientKey": "$NOSTR_CLIENT_KEY"
      },
      "reporting": {
        "dmRelays": ["wss://relay.example.com"],
        "outboxRelays": ["wss://relay.example.com"],
        "relayListBootstrapRelays": ["wss://relay.damus.io", "wss://purplepag.es"],
        "appDataRelays": ["wss://relay.example.com"],
        "signerRelays": ["wss://relay.example.com"],
        "reportTo": ["npub1operator..."],
        "allowFrom": ["npub1operator..."]
      },
      "nostr_git": {
        "graspServers": ["wss://replace-with-grasp-server"],
        "gitDataRelays": [
          "wss://relay.damus.io",
          "wss://nos.lol",
          "wss://relay.example.com",
          "wss://relay.ngit.dev",
          "wss://gitnostr.com"
        ]
      }
    },
    "qa-01": {
      "identity": {
        "npub": "npub1qa...",
        "sec": "$OPENTEAM_QA_01_SEC",
        "bunkerProfile": "qa-01",
        "nakClientKey": "$NOSTR_CLIENT_KEY"
      },
      "reporting": {
        "dmRelays": ["wss://relay.example.com"],
        "outboxRelays": ["wss://relay.example.com"],
        "relayListBootstrapRelays": ["wss://relay.damus.io", "wss://purplepag.es"],
        "appDataRelays": ["wss://relay.example.com"],
        "signerRelays": ["wss://relay.example.com"],
        "reportTo": ["npub1operator..."],
        "allowFrom": ["npub1operator..."]
      },
      "nostr_git": {
        "graspServers": ["wss://replace-with-grasp-server"],
        "gitDataRelays": [
          "wss://relay.damus.io",
          "wss://nos.lol",
          "wss://relay.example.com",
          "wss://relay.ngit.dev",
          "wss://gitnostr.com"
        ]
      }
    }
  }
}
