# Copy this file to config/openteam.secrets.env and fill the values.
# openteam loads config/openteam.secrets.env automatically if it exists.

# Git provider tokens shared across agents
OPENTEAM_GITHUB_TOKEN=
OPENTEAM_GITLAB_TOKEN=

# Target app/repo root
OPENTEAM_APP_ROOT=

# Optional Nostr client key used by nak when talking to bunkers
NOSTR_CLIENT_KEY=

# Agent Nostr secrets (nsec1... or 64-char hex)
OPENTEAM_TRIAGER_01_SEC=
OPENTEAM_BUILDER_01_SEC=
OPENTEAM_QA_01_SEC=
