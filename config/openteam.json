{
  "runtimeRoot": "./runtime",
  "opencode": {
    "binary": "opencode",
    "model": "",
    "agent": "build"
  },
  "browser": {
    "headless": false,
    "mcp": {
      "name": "playwright",
      "command": [],
      "environment": {}
    }
  },
  "providers": {},
  "repos": {
    "control": {
      "root": ".",
      "baseBranch": "master",
      "sharedPaths": [],
      "mode": "code"
    },
    "app": {
      "root": "$OPENTEAM_APP_ROOT",
      "baseBranch": "dev",
      "devCommand": [
        "bun",
        "run",
        "dev",
        "--",
        "--config",
        "{viteConfig}",
        "--host",
        "127.0.0.1",
        "--port",
        "{port}"
      ],
      "healthUrl": "http://127.0.0.1:{port}",
      "sharedPaths": ["node_modules"],
      "mode": "web"
    }
  },
  "reporting": {
    "dmRelays": [],
    "outboxRelays": [],
    "relayListBootstrapRelays": [],
    "appDataRelays": [],
    "signerRelays": [],
    "allowFrom": [],
    "reportTo": [],
