  },
  "nostr_git": {
    "graspServers": [],
    "gitDataRelays": [],
    "repoAnnouncementRelays": [],
    "forkGitOwner": "",
    "forkRepoPrefix": "",
    "forkCloneUrlTemplate": ""
  },
  "agents": {
    "triager-01": {
      "role": "triager",
      "soul": "triager",
      "repo": "app",
      "portStart": 18472,
      "reporting": {},
      "identity": {
        "npub": "",
        "sec": "",
        "bunkerProfile": "triager-01",
        "nakClientKey": "$NOSTR_CLIENT_KEY"
      },
      "nostr_git": {}
    },
    "orchestrator-01": {
      "role": "orchestrator",
      "soul": "orchestrator",
